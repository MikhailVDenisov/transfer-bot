# Telegram Bot Configuration
TELEGRAM_TOKEN={{ telegram_token }}

# Database Configuration
DATABASE_URL={{ database_url | default('sqlite:///transfer_bot.db') }}

# Bot Settings
WAITING_LIST_CHECK_INTERVAL={{ waiting_list_check_interval | default('300') }}

# Logging
LOG_LEVEL={{ log_level | default('INFO') }}

# Google Sheets (если используется)
{% if google_credentials_file is defined %}
GOOGLE_CREDENTIALS_FILE={{ google_credentials_file }}
{% endif %}
{% if google_sheet_id is defined %}
GOOGLE_SHEET_ID={{ google_sheet_id }}
{% endif %}
